# Database Configuration
DB_PASSWORD=change_me_in_production
DATABASE_URL=postgres://smartlms:${DB_PASSWORD}@localhost:5432/smartlms_master

# Redis Configuration
REDIS_URL=redis://localhost:6379

# JWT Configuration
JWT_SECRET=change_me_use_strong_random_secret_here
JWT_EXPIRY_HOURS=24

# Application Configuration
RUST_LOG=info
APP_HOST=0.0.0.0
APP_PORT=8080
MAX_UPLOAD_SIZE=52428800

# Admin Configuration
ADMIN_EMAIL=admin@smartlms.example.com
ADMIN_PASSWORD=change_me_in_production

# Email Configuration (optional)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@smartlms.example.com

# SSO Configuration (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Monitoring
PROMETHEUS_ENABLED=true
GRAFANA_PASSWORD=admin

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_RETENTION_DAYS=30